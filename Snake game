<!DOCTYPE html>
<html lang="hi">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>क्लासिक स्नेक गेम</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }

        body {
            background: #111424;
            color: white;
            font-family: 'Segoe UI', Arial, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            overflow: hidden;
        }

        h1 {
            margin-bottom: 10px;
            color: #4caf50;
            text-shadow: 0 0 10px rgba(76, 175, 80, 0.3);
        }

        #score-board {
            font-size: 20px;
            font-weight: bold;
            margin-bottom: 15px;
            letter-spacing: 1px;
        }

        /* गेम स्क्रीन */
        #game-canvas {
            background: #1a1a2e;
            border: 4px solid #4caf50;
            border-radius: 10px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
        }

        /* गेम ओवर या स्टार्ट का मैसेज */
        #overlay {
            position: absolute;
            background: rgba(15, 15, 35, 0.9);
            border: 2px solid #ff3366;
            padding: 30px;
            border-radius: 15px;
            text-align: center;
            box-shadow: 0 0 20px rgba(255, 51, 102, 0.4);
            display: flex;
            flex-direction: column;
            gap: 15px;
            z-index: 10;
        }

        #start-btn {
            background: linear-gradient(135deg, #4caf50, #2e7d32);
            color: white;
            border: none;
            padding: 12px 30px;
            font-size: 16px;
            font-weight: bold;
            border-radius: 25px;
            cursor: pointer;
            box-shadow: 0 4px 15px rgba(76, 175, 80, 0.4);
            transition: transform 0.1s;
        }

        #start-btn:active {
            transform: scale(0.95);
        }
    </style>
</head>
<body>

    <h1>SNAKE GAME</h1>
    <div id="score-board">SCORE: <span id="score">0</span></div>

    <div style="position: relative;">
        <canvas id="game-canvas" width="400" height="400"></canvas>

        <div id="overlay">
            <h2 id="msg-text">🏁 खेलने के लिए बटन दबाएं</h2>
            <button id="start-btn">START GAME</button>
        </div>
    </div>

    <script>
        const canvas = document.getElementById("game-canvas");
        const ctx = canvas.getContext("2d");
        const scoreDisplay = document.getElementById("score");
        const overlay = document.getElementById("overlay");
        const msgText = document.getElementById("msg-text");
        const startBtn = document.getElementById("start-btn");

        // ग्रिड साइज (हर ब्लॉक का आकार)
        const gridSize = 20; 
        const tileCount = canvas.width / gridSize; // 20x20 की ग्रिड बनेगी

        let snake = [];
        let food = { x: 5, y: 5 };
        let dx = gridSize; // शुरुआत में राइट दिशा में चलेगा
        let dy = 0;
        let score = 0;
        let gameInterval = null;
        let isGameOver = true;

        // कीबोर्ड कंट्रोल्स
        document.addEventListener("keydown", changeDirection);

        startBtn.addEventListener("click", () => {
            resetGame();
        });

        function resetGame() {
            snake = [
                { x: 160, y: 200 },
                { x: 140, y: 200 },
                { x: 120, y: 200 }
            ];
            score = 0;
            dx = gridSize;
            dy = 0;
            isGameOver = false;
            scoreDisplay.innerText = score;
            overlay.style.display = "none";
            
            if (gameInterval) clearInterval(gameInterval);
            // गेम की स्पीड (100ms यानी हर सेकंड 10 फ्रेम)
            gameInterval = setInterval(updateGame, 100); 
        }

        function updateGame() {
            if (isGameOver) return;

            // सांप का अगला कदम (Head)
            const head = { x: snake[0].x + dx, y: snake[0].y + dy };

            // दीवारों से टकराने की चेकिंग (बाउंड्री कंडीशन)
            if (head.x < 0 || head.x >= canvas.width || head.y < 0 || head.y >= canvas.height) {
                endGame();
                return;
            }

            // खुद के शरीर से टकराने की चेकिंग
            for (let i = 0; i < snake.length; i++) {
                if (snake[i].x === head.x && snake[i].y === head.y) {
                    endGame();
                    return;
                }
            }

            // सांप के सिर को आगे जोड़ना
            snake.unshift(head);

            // खाना (Food) खाने की चेकिंग
            if (head.x === food.x && head.y === food.y) {
                score += 10;
                scoreDisplay.innerText = score;
                generateFood();
            } else {
                // अगर खाना नहीं खाया, तो पूंछ का आखिरी हिस्सा हटा देते हैं ताकि सांप आगे बढ़ता हुआ दिखे
                snake.pop();
            }

            drawEverything();
        }

        // स्क्रीन पर सब कुछ रेंडर करना
        function drawEverything() {
            // कैनवास साफ करना
            ctx.fillStyle = "#1a1a2e";
            ctx.fillRect(0, 0, canvas.width, canvas.height);

            // खाना (Food) बनाना
            ctx.fillStyle = "#ff3366";
            ctx.shadowBlur = 10;
            ctx.shadowColor = "#ff3366";
            ctx.fillRect(food.x, food.y, gridSize - 2, gridSize - 2);

            // सांप (Snake) बनाना
            snake.forEach((part, index) => {
                // सिर का रंग थोड़ा अलग (चमकदार हरा) और बॉडी का नॉर्मल हरा
                ctx.fillStyle = index === 0 ? "#69f0ae" : "#4caf50";
                ctx.shadowBlur = index === 0 ? 8 : 0;
                ctx.shadowColor = "#69f0ae";
                ctx.fillRect(part.x, part.y, gridSize - 2, gridSize - 2);
            });
            
            // शैडो इफ़ेक्ट रीसेट करना
            ctx.shadowBlur = 0;
        }

        // रैंडम जगह पर खाना पैदा करना
        function generateFood() {
            food.x = Math.floor(Math.random() * tileCount) * gridSize;
            food.y = Math.floor(Math.random() * tileCount) * gridSize;

            // खाना सांप के शरीर के ऊपर न पैदा हो, इसकी चेकिंग
            snake.forEach(part => {
                if (part.x === food.x && part.y === food.y) {
                    generateFood();
                }
            });
        }

        // दिशा बदलना (उल्टी दिशा में जाने से रोकना)
        function changeDirection(event) {
            const keyPressed = event.key;
            const goingUp = (dy === -gridSize);
            const goingDown = (dy === gridSize);
            const goingRight = (dx === gridSize);
            const goingLeft = (dx === -gridSize);

            if (keyPressed === "ArrowLeft" && !goingRight) {
                dx = -gridSize;
                dy = 0;
            }
            if (keyPressed === "ArrowUp" && !goingDown) {
                dx = 0;
                dy = -gridSize;
            }
            if (keyPressed === "ArrowRight" && !goingLeft) {
                dx = gridSize;
                dy = 0;
            }
            if (keyPressed === "ArrowDown" && !goingUp) {
                dx = 0;
                dy = gridSize;
            }
        }

        function endGame() {
            isGameOver = true;
            clearInterval(gameInterval);
            msgText.innerHTML = `💥 GAME OVER 💥<br><br>आपका स्कोर: ${score}`;
            startBtn.innerText = "RESTART";
            overlay.style.display = "flex";
        }
    </script>
</body>
</html>
